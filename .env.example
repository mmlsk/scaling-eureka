# Stock Market APIs — serwerowe (NIE eksponuj do klienta)
FINNHUB_NEWS_KEY=
ALPHA_VANTAGE_KEY=
POLYGON_KEY=

# Macro / Energy — serwerowe
FRED_API_KEY=
EIA_API_KEY=

# Weather (mogą być publiczne — używane bezpośrednio z FE w niektórych przypadkach, OK z NEXT_PUBLIC_)
NEXT_PUBLIC_OPENAQ_KEY=
NEXT_PUBLIC_OPENUV_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI (server-only)
OPENAI_API_KEY=

# Google Calendar (server-only)
GOOGLE_CAL_API_KEY=
GOOGLE_CAL_CALENDAR_ID=

# Calendar ID (public — może być NEXT_PUBLIC_)
NEXT_PUBLIC_GOOGLE_CAL_CALENDAR_ID=

# Lokalizacja (defaults: Szczecin, PL)
NEXT_PUBLIC_LATITUDE=53.43
NEXT_PUBLIC_LONGITUDE=14.55
NEXT_PUBLIC_TIMEZONE=Europe/Warsaw
NEXT_PUBLIC_CITY=Szczecin
NEXT_PUBLIC_COUNTRY=PL
