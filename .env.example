# LIFE OS Configuration Template
# Copy this to .env and customize for your deployment

# Timezone Configuration
TIMEZONE=Europe/Berlin
TIMEZONE_OFFSET_HOURS=2
LATITUDE=53.4285
LONGITUDE=14.5528
CITY_NAME=Szczecin

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=80
SERVER_SSL_PORT=443

# Enable HTTPS
ENABLE_HTTPS=false
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# Performance
ENABLE_GZIP=true
CACHE_MAX_AGE=86400
MIN_JS_CSS=true

# Security
ENABLE_CSP=true
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000

# External APIs
OPENMETEO_API_URL=https://api.open-meteo.com/v1/forecast
OPENMETEO_TIMEOUT_MS=5000

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined
ACCESS_LOG=/var/log/app/access.log
ERROR_LOG=/var/log/app/error.log

# Monitoring
ENABLE_HEALTH_CHECK=true
HEALTH_CHECK_INTERVAL_SECONDS=30

# User Features
ENABLE_THEME_PERSISTENCE=true
ENABLE_LOCAL_STORAGE=true
LOCAL_STORAGE_QUOTA_MB=5

# Browser Support
MIN_CHROME_VERSION=90
MIN_FIREFOX_VERSION=88
MIN_SAFARI_VERSION=14
